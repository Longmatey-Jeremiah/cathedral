NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/church_db?schema=public

JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=1h

INVITE_TOKEN_TTL_HOURS=72
APP_URL=http://localhost:3000

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="Church Platform <noreply@church.app>"

# Bootstrap super admin (used by `npm run prisma:seed`)
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=change-me-please-min-12-chars
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
